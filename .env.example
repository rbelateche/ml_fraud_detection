# Example environment configuration. Copy to `.env` and adjust.
# All variables are optional — sensible defaults live in src/fraud_detection/config.py.

# Data backend: "synthetic" (default, no credentials) or "kaggle".
FRAUD_DATA_SOURCE=synthetic

# Synthetic generator knobs.
FRAUD_SYNTH_N_TRANSACTIONS=200000
FRAUD_SYNTH_FRAUD_RATE=0.012

# Reproducibility.
FRAUD_RANDOM_SEED=42

# Business cost model (used for cost-based threshold tuning).
FRAUD_COST_FALSE_POSITIVE_COST=5.0
FRAUD_COST_FALSE_NEGATIVE_AMOUNT_FRACTION=1.0
FRAUD_COST_REVIEW_COST=1.0

# Kaggle backend (only if FRAUD_DATA_SOURCE=kaggle).
# Requires ~/.kaggle/kaggle.json (chmod 600). For IEEE-CIS set the competition.
FRAUD_KAGGLE_DATASET=kartik2112/fraud-detection
# FRAUD_KAGGLE_COMPETITION=ieee-fraud-detection

# MLflow (Phase 0.5). Defaults to a local SQLite backend (./mlflow.db).
# Set to a remote/shared tracking server if desired.
# MLFLOW_TRACKING_URI=sqlite:///mlflow.db
